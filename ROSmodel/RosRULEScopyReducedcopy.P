/******************************************************
 * RosRULEScopy.P
 *
 * RULES ONLY
 * - generic rules
 * - no hardcoded case-study names
 * - no facts / no goals
 ******************************************************/

:- dynamic primitive/1.
:- dynamic derived/1.
:- dynamic meta/1.
:- dynamic interaction_rule/2.

% ====================================================
% PRIMITIVES
% ====================================================

% ---- Core structure ----
primitive(system(_sys)).
primitive(rosApplication(_appName)).
primitive(rosNode(_nodeName)).
primitive(programImplementsNode(_program,_nodeName)).

% ---- Topic structure ----
primitive(rosTopic(_topicName)).
primitive(topicPublisher(_topic,_node)).
primitive(topicSubscriber(_topic,_node)).
primitive(allowedPublisher(_topic,_node)).
primitive(allowedSubscriber(_topic,_node)).
primitive(topicAcceptsExternalPublish(_topicName)).
primitive(topicType(_topic,_rosMsgType)).
primitive(pubType(_node,_topic,_rosMsgType)).
primitive(subType(_node,_topic,_rosMsgType)).

primitive(controlTopic(_topic)).
primitive(sensorTopic(_topic)).
primitive(sensitiveTopic(_topic)).

% ---- Service structure ----
primitive(serviceServer(_serviceName,_serverNode)).
primitive(serviceType(_serviceName,_srvType)).
primitive(parameterService(_serviceName)).
primitive(lifecycleService(_serviceName)).

% ---- DDS / network ----
primitive(netAccess(_node,_proto,_port)).
primitive(ddsSecurityDisabled(_node)).

% ---- Realistic attacker foothold facts ----
primitive(attackerEntryPoint(_host)).
primitive(hostReachable(_srcHost,_dstHost)).
primitive(hostRunsRos(_host)).
primitive(hostStoresRosCredentials(_host)).
primitive(hostHasNetAdmin(_host)).
primitive(nodeHostedOn(_node,_host)).

% ---- Optional code-path facts (kept for completeness) ----
primitive(programPathDisclosed(_program)).
primitive(programFileWritable(_program)).

% ---- System impact mapping ----
primitive(topicBelongsToSystem(_topic,_sys)).
primitive(nodeAffectsSystem(_node,_sys)).

% ---- Vulnerability / software info ----
primitive(vulExists(_cve,_program)).
primitive(vulProperty(_cve,_vector,_effect)).
primitive(processesArray(_program,_topic)).
primitive(handlesTLS(_program)).

% ====================================================
% DERIVED PREDICATES
% ====================================================

% ---- Benign ROS graph structure ----
derived(rtpsReachableNode(_node)).
derived(typeOkPublisher(_node,_topic)).
derived(typeOkSubscriber(_node,_topic)).
derived(nodePublishesToTopic(_node,_topic)).
derived(nodeSubscribesToTopic(_node,_topic)).
derived(rosService(_serviceName,_node)).

% ---- Recon / target selection ----
derived(initialAccess(_host)).
derived(lateralAccess(_host)).
derived(credentialAccess(_host)).
derived(attackerOnRosNetwork(_host)).
derived(attackerCanJoinRosGraph(_host)).
derived(attackerCanNetAdmin(_host)).

derived(graphDiscovery(_node)).
derived(targetNodeSelected(_node)).

% ---- Executable attacker operations from graph access ----
derived(topicRead(_topic)).
derived(topicWrite(_topic)).
derived(topicFlood(_topic)).
derived(serviceCall(_serviceName,_serverNode)).
derived(exfiltrateTopicData(_topic)).

% ---- Trusted-node abuse after compromise ----
derived(maliciousTopicContent(_topic)).
derived(topicDrop(_topic)).
derived(topicDelay(_topic)).
derived(qosDegradation(_topic)).

% ---- Derived attacker capabilities ----
derived(mitmPossible(_topic)).
derived(infoLeak(_topic)).
derived(topicInfluence(_topic)).
derived(parameterTamper(_node)).
derived(lifecycleAbuse(_node)).
derived(cryptoInfoLeak(_topic)).
derived(arrayDosExploit(_node,_topic)).

% ---- Direct security consequences ----
derived(commandIntegrityLoss(_topic)).
derived(sensorIntegrityLoss(_topic)).
derived(sensorAvailabilityLoss(_topic)).
derived(configurationIntegrityLoss(_node)).
derived(lifecycleDisruption(_node)).
derived(dos(_node)).

% ---- System-level consequences ----
derived(confidentialityCompromise(_sys)).
derived(operationalCompromise(_sys)).
derived(availabilityCompromise(_sys)).
derived(systemCompromised(_sys)).

% ====================================================
% INTERACTION RULES
% ====================================================

% ----------------------------------------------------
% A) Benign ROS graph plumbing
% ----------------------------------------------------

interaction_rule(
  (rtpsReachableNode(Node) :-
     netAccess(Node, rtps, 7400)),
  rule_desc('RTPS reachable node',1)).

interaction_rule(
  (typeOkPublisher(Node,Topic) :-
     topicType(Topic,T),
     pubType(Node,Topic,T)),
  rule_desc('Publisher type matches topic',1)).

interaction_rule(
  (typeOkSubscriber(Node,Topic) :-
     topicType(Topic,T),
     subType(Node,Topic,T)),
  rule_desc('Subscriber type matches topic',1)).

interaction_rule(
  (nodePublishesToTopic(Node,Topic) :-
     rosTopic(Topic),
     topicPublisher(Topic,Node),
     allowedPublisher(Topic,Node),
     typeOkPublisher(Node,Topic)),
  rule_desc('Node publishes to topic',1)).

interaction_rule(
  (nodeSubscribesToTopic(Node,Topic) :-
     rosTopic(Topic),
     topicSubscriber(Topic,Node),
     allowedSubscriber(Topic,Node),
     typeOkSubscriber(Node,Topic)),
  rule_desc('Node subscribes to topic',1)).

interaction_rule(
  (rosService(Srv,Server) :-
     serviceServer(Srv,Server),
     serviceType(Srv,_Type)),
  rule_desc('Service exists on server',1)).

% ----------------------------------------------------
% B) External DDS/graph reconnaissance
% ----------------------------------------------------

interaction_rule(
  (initialAccess(Host) :-
     attackerEntryPoint(Host)),
  rule_desc('Attacker gains initial access to an entry host',1)).

interaction_rule(
  (lateralAccess(DstHost) :-
     initialAccess(SrcHost),
     hostReachable(SrcHost,DstHost)),
  rule_desc('Attacker laterally reaches another host',1)).

interaction_rule(
  (credentialAccess(Host) :-
     lateralAccess(Host),
     hostStoresRosCredentials(Host)),
  rule_desc('Attacker obtains ROS credentials from reached host',1)).

interaction_rule(
  (attackerOnRosNetwork(Host) :-
     lateralAccess(Host),
     hostRunsRos(Host)),
  rule_desc('Attacker is positioned on ROS network',1)).

interaction_rule(
  (attackerCanJoinRosGraph(Host) :-
     attackerOnRosNetwork(Host),
     credentialAccess(Host)),
  rule_desc('Attacker can join ROS graph as an authorized participant',1)).

interaction_rule(
  (attackerCanJoinRosGraph(Host) :-
     attackerOnRosNetwork(Host),
     rtpsReachableNode(Node),
     ddsSecurityDisabled(Node)),
  rule_desc('Attacker can join ROS graph when DDS security is disabled',1)).

interaction_rule(
  (attackerCanNetAdmin(Host) :-
     lateralAccess(Host),
     hostHasNetAdmin(Host)),
  rule_desc('Attacker has host privilege for network shaping',1)).

interaction_rule(
  (graphDiscovery(Node) :-
     rtpsReachableNode(Node),
     attackerOnRosNetwork(_Host)),
  rule_desc('Attacker discovers ROS node through exposed DDS graph',1)).

interaction_rule(
  (targetNodeSelected(Node) :-
     graphDiscovery(Node),
     nodeAffectsSystem(Node,_Sys)),
  rule_desc('Attacker selects impactful target node',1)).

% ----------------------------------------------------
% C) Real attacker operations from exposed ROS graph
% ----------------------------------------------------

interaction_rule(
  (topicRead(Topic) :-
     rosTopic(Topic),
     nodePublishesToTopic(Pub,Topic),
     attackerCanJoinRosGraph(_Host),
     rtpsReachableNode(Pub),
     ddsSecurityDisabled(Pub)),
  rule_desc('Attacker reads topic',1)).

interaction_rule(
  (topicWrite(Topic) :-
     rosTopic(Topic),
     topicAcceptsExternalPublish(Topic),
     nodeSubscribesToTopic(Sub,Topic),
     attackerCanJoinRosGraph(_Host),
     rtpsReachableNode(Sub),
     ddsSecurityDisabled(Sub)),
  rule_desc('Attacker writes topic',1)).

interaction_rule(
  (topicFlood(Topic) :-
     topicWrite(Topic)),
  rule_desc('Attacker floods topic',1)).

interaction_rule(
  (serviceCall(Srv,Server) :-
     rosService(Srv,Server),
     attackerCanJoinRosGraph(_Host),
     rtpsReachableNode(Server),
     ddsSecurityDisabled(Server)),
  rule_desc('Attacker calls service',1)).

interaction_rule(
  (exfiltrateTopicData(Topic) :-
     topicRead(Topic),
     sensitiveTopic(Topic)),
  rule_desc('Attacker exfiltrates topic data',1)).

% ----------------------------------------------------
% D) Runtime sensor-channel abuse (non-intrusive)
% ----------------------------------------------------

interaction_rule(
  (maliciousTopicContent(Topic) :-
     targetNodeSelected(Node),
     nodePublishesToTopic(Node,Topic),
     attackerCanJoinRosGraph(_Host),
     sensorTopic(Topic)),
  rule_desc('Authorized rogue participant tampers sensor topic content',1)).

interaction_rule(
  (topicDrop(Topic) :-
     targetNodeSelected(Node),
     nodePublishesToTopic(Node,Topic),
     nodeHostedOn(Node,Host),
     attackerCanNetAdmin(Host),
     sensorTopic(Topic)),
  rule_desc('Attacker drops sensor topic via network impairment',1)).

interaction_rule(
  (topicDelay(Topic) :-
     targetNodeSelected(Node),
     nodePublishesToTopic(Node,Topic),
     nodeHostedOn(Node,Host),
     attackerCanNetAdmin(Host),
     sensorTopic(Topic)),
  rule_desc('Attacker delays sensor topic via network impairment',1)).

interaction_rule(
  (qosDegradation(Topic) :-
     targetNodeSelected(Node),
     nodePublishesToTopic(Node,Topic),
     attackerCanJoinRosGraph(_Host),
     sensorTopic(Topic)),
  rule_desc('Authorized rogue participant degrades sensor QoS',1)).

% ----------------------------------------------------
% E) Derived attacker capabilities
% ----------------------------------------------------

interaction_rule(
  (mitmPossible(Topic) :-
     topicRead(Topic),
     topicWrite(Topic)),
  rule_desc('Attacker can read and write topic',1)).

interaction_rule(
  (infoLeak(Topic) :-
     topicRead(Topic)),
  rule_desc('Topic data leaked',1)).

interaction_rule(
  (topicInfluence(Topic) :-
     topicWrite(Topic)),
  rule_desc('Attacker influences topic through external write',1)).

interaction_rule(
  (topicInfluence(Topic) :-
     maliciousTopicContent(Topic)),
  rule_desc('Compromised trusted publisher influences topic',1)).

interaction_rule(
  (parameterTamper(Node) :-
     serviceCall(Srv,Node),
     parameterService(Srv)),
  rule_desc('Attacker tampers parameters',1)).

interaction_rule(
  (lifecycleAbuse(Node) :-
     serviceCall(Srv,Node),
     lifecycleService(Srv)),
  rule_desc('Attacker abuses lifecycle service',1)).

interaction_rule(
  (cryptoInfoLeak(Topic) :-
     mitmPossible(Topic),
     nodePublishesToTopic(Node,Topic),
     programImplementsNode(Program,Node),
     handlesTLS(Program),
     vulExists('crypto_infoleak_family',Program),
     vulProperty('crypto_infoleak_family',remoteExploit,infoLeak)),
  rule_desc('Crypto family leaks data',1)).

interaction_rule(
  (arrayDosExploit(Node,Topic) :-
     topicWrite(Topic),
     nodeSubscribesToTopic(Node,Topic),
     programImplementsNode(Program,Node),
     processesArray(Program,Topic),
     vulExists('GHSA-5545-2q6w-2gh6',Program),
     vulProperty('GHSA-5545-2q6w-2gh6',remoteExploit,dos)),
  rule_desc('Array input triggers DoS exploit',1)).

% ----------------------------------------------------
% F) Direct consequences
% ----------------------------------------------------

interaction_rule(
  (commandIntegrityLoss(Topic) :-
     topicInfluence(Topic),
     controlTopic(Topic)),
  rule_desc('Control topic integrity lost',1)).

interaction_rule(
  (sensorIntegrityLoss(Topic) :-
     topicInfluence(Topic),
     sensorTopic(Topic)),
  rule_desc('Sensor topic integrity lost',1)).

interaction_rule(
  (sensorAvailabilityLoss(Topic) :-
     topicDrop(Topic),
     sensorTopic(Topic)),
  rule_desc('Sensor topic unavailable due to dropped messages',1)).

interaction_rule(
  (sensorAvailabilityLoss(Topic) :-
     topicDelay(Topic),
     sensorTopic(Topic)),
  rule_desc('Sensor topic unavailable due to delayed messages',1)).

interaction_rule(
  (sensorAvailabilityLoss(Topic) :-
     qosDegradation(Topic),
     sensorTopic(Topic)),
  rule_desc('Sensor topic degraded by QoS manipulation',1)).

interaction_rule(
  (configurationIntegrityLoss(Node) :-
     parameterTamper(Node)),
  rule_desc('Configuration integrity lost',1)).

interaction_rule(
  (lifecycleDisruption(Node) :-
     lifecycleAbuse(Node)),
  rule_desc('Lifecycle disrupted',1)).

interaction_rule(
  (dos(Node) :-
     arrayDosExploit(Node,_Topic)),
  rule_desc('Node denied service by exploit',1)).

interaction_rule(
  (dos(Node) :-
     nodeSubscribesToTopic(Node,Topic),
     topicFlood(Topic)),
  rule_desc('Node denied service by topic flood',1)).

% ----------------------------------------------------
% G) System-level consequences
% ----------------------------------------------------

interaction_rule(
  (confidentialityCompromise(Sys) :-
     exfiltrateTopicData(Topic),
     topicBelongsToSystem(Topic,Sys)),
  rule_desc('System confidentiality compromised by topic exfiltration',1)).

interaction_rule(
  (confidentialityCompromise(Sys) :-
     cryptoInfoLeak(Topic),
     topicBelongsToSystem(Topic,Sys)),
  rule_desc('System confidentiality compromised by crypto leak',1)).

interaction_rule(
  (operationalCompromise(Sys) :-
     commandIntegrityLoss(Topic),
     topicBelongsToSystem(Topic,Sys)),
  rule_desc('System operation compromised by control topic loss',1)).

interaction_rule(
  (operationalCompromise(Sys) :-
     sensorIntegrityLoss(Topic),
     topicBelongsToSystem(Topic,Sys)),
  rule_desc('System operation compromised by sensor topic integrity loss',1)).

interaction_rule(
  (operationalCompromise(Sys) :-
     sensorAvailabilityLoss(Topic),
     topicBelongsToSystem(Topic,Sys)),
  rule_desc('System operation compromised by sensor topic delivery loss',1)).

interaction_rule(
  (operationalCompromise(Sys) :-
     configurationIntegrityLoss(Node),
     nodeAffectsSystem(Node,Sys)),
  rule_desc('System operation compromised by parameter tamper',1)).

interaction_rule(
  (operationalCompromise(Sys) :-
     lifecycleDisruption(Node),
     nodeAffectsSystem(Node,Sys)),
  rule_desc('System operation compromised by lifecycle abuse',1)).

interaction_rule(
  (availabilityCompromise(Sys) :-
     dos(Node),
     nodeAffectsSystem(Node,Sys)),
  rule_desc('System availability compromised by node DoS',1)).

interaction_rule(
  (systemCompromised(Sys) :-
     operationalCompromise(Sys)),
  rule_desc('System compromised by operational loss',1)).

interaction_rule(
  (systemCompromised(Sys) :-
     confidentialityCompromise(Sys)),
  rule_desc('System compromised by confidentiality loss',1)).

interaction_rule(
  (systemCompromised(Sys) :-
     availabilityCompromise(Sys)),
  rule_desc('System compromised by availability loss',1)).

derived(rtpsReachableNode(_node)).
derived(typeOkPublisher(_node,_topic)).
derived(typeOkSubscriber(_node,_topic)).
derived(nodePublishesToTopic(_node,_topic)).
derived(nodeSubscribesToTopic(_node,_topic)).
derived(rosService(_serviceName,_node)).

% ---- Recon / target selection ----
derived(initialAccess(_host)).
derived(lateralAccess(_host)).
derived(credentialAccess(_host)).
derived(attackerOnRosNetwork(_host)).
derived(attackerCanJoinRosGraph(_host)).
derived(attackerCanNetAdmin(_host)).

derived(graphDiscovery(_node)).
derived(targetNodeSelected(_node)).

% ---- Executable attacker operations ----
derived(topicRead(_topic)).
derived(topicWrite(_topic)).
derived(topicFlood(_topic)).
derived(serviceCall(_serviceName,_serverNode)).
derived(exfiltrateTopicData(_topic)).

% ---- Trusted-node abuse after compromise ----
derived(maliciousTopicContent(_topic)).
derived(topicDrop(_topic)).
derived(topicDelay(_topic)).
derived(qosDegradation(_topic)).

% ---- Derived attacker capabilities ----
derived(mitmPossible(_topic)).
derived(infoLeak(_topic)).
derived(topicInfluence(_topic)).
derived(parameterTamper(_node)).
derived(lifecycleAbuse(_node)).
derived(cryptoInfoLeak(_topic)).
derived(arrayDosExploit(_node,_topic)).

% ---- Second-stage escalation attacks ----
derived(mitmInjection(_topic)).
derived(gradualDrift(_topic)).
derived(stalePublish(_topic)).
derived(crossTopicCorrelation(_sys)).
derived(reliabilityFlip(_topic)).
derived(lifecycleHijack(_node)).

% ---- Exfiltration via covert channel ----
derived(exfiltrateChannel(_topic)).

% ---- Observable EFFECT predicates (monitor-detected) ----

% ====================================================
% INTERACTION RULES
% ====================================================

% ----------------------------------------------------
% A) Benign ROS graph plumbing
% ----------------------------------------------------

interaction_rule(
  (rtpsReachableNode(Node) :-
     netAccess(Node, rtps, 7400)),
  rule_desc('RTPS reachable node',1)).

interaction_rule(
  (typeOkPublisher(Node,Topic) :-
     topicType(Topic,T),
     pubType(Node,Topic,T)),
  rule_desc('Publisher type matches topic',1)).

interaction_rule(
  (typeOkSubscriber(Node,Topic) :-
     topicType(Topic,T),
     subType(Node,Topic,T)),
  rule_desc('Subscriber type matches topic',1)).

interaction_rule(
  (nodePublishesToTopic(Node,Topic) :-
     rosTopic(Topic),
     topicPublisher(Topic,Node),
     allowedPublisher(Topic,Node),
     typeOkPublisher(Node,Topic)),
  rule_desc('Node publishes to topic',1)).

interaction_rule(
  (nodeSubscribesToTopic(Node,Topic) :-
     rosTopic(Topic),
     topicSubscriber(Topic,Node),
     allowedSubscriber(Topic,Node),
     typeOkSubscriber(Node,Topic)),
  rule_desc('Node subscribes to topic',1)).

interaction_rule(
  (rosService(Srv,Server) :-
     serviceServer(Srv,Server),
     serviceType(Srv,_Type)),
  rule_desc('Service exists on server',1)).

% ----------------------------------------------------
% B) External DDS/graph reconnaissance
% ----------------------------------------------------

interaction_rule(
  (initialAccess(Host) :-
     attackerEntryPoint(Host)),
  rule_desc('Attacker gains initial access to an entry host',1)).

interaction_rule(
  (lateralAccess(DstHost) :-
     initialAccess(SrcHost),
     hostReachable(SrcHost,DstHost)),
  rule_desc('Attacker laterally reaches another host',1)).

interaction_rule(
  (credentialAccess(Host) :-
     lateralAccess(Host),
     hostStoresRosCredentials(Host)),
  rule_desc('Attacker obtains ROS credentials from reached host',1)).

interaction_rule(
  (attackerOnRosNetwork(Host) :-
     lateralAccess(Host),
     hostRunsRos(Host)),
  rule_desc('Attacker is positioned on ROS network',1)).

interaction_rule(
  (attackerCanJoinRosGraph(Host) :-
     attackerOnRosNetwork(Host),
     credentialAccess(Host)),
  rule_desc('Attacker can join ROS graph as an authorized participant',1)).

interaction_rule(
  (attackerCanNetAdmin(Host) :-
     lateralAccess(Host),
     hostHasNetAdmin(Host)),
  rule_desc('Attacker has host privilege for network shaping',1)).

interaction_rule(
  (graphDiscovery(Node) :-
     rtpsReachableNode(Node),
     attackerOnRosNetwork(_Host)),
  rule_desc('Attacker discovers ROS node through exposed DDS graph',1)).

interaction_rule(
  (targetNodeSelected(Node) :-
     graphDiscovery(Node),
     nodeAffectsSystem(Node,_Sys)),
  rule_desc('Attacker selects impactful target node',1)).

% ----------------------------------------------------
% C) Attacker operations from exposed ROS graph
% ----------------------------------------------------

interaction_rule(
  (topicRead(Topic) :-
     rosTopic(Topic),
     nodePublishesToTopic(Pub,Topic),
     attackerCanJoinRosGraph(_Host),
     rtpsReachableNode(Pub),
     ddsSecurityDisabled(Pub)),
  rule_desc('Attacker reads topic',1)).

interaction_rule(
  (topicWrite(Topic) :-
     rosTopic(Topic),
     topicAcceptsExternalPublish(Topic),
     nodeSubscribesToTopic(Sub,Topic),
     attackerCanJoinRosGraph(_Host),
     rtpsReachableNode(Sub),
     ddsSecurityDisabled(Sub)),
  rule_desc('Attacker writes topic',1)).

interaction_rule(
  (topicFlood(Topic) :-
     topicWrite(Topic),
     controlTopic(Topic)),
  rule_desc('Attacker floods topic',1)).

interaction_rule(
  (serviceCall(Srv,Server) :-
     rosService(Srv,Server),
     attackerCanJoinRosGraph(_Host),
     rtpsReachableNode(Server),
     ddsSecurityDisabled(Server)),
  rule_desc('Attacker calls service',1)).

interaction_rule(
  (exfiltrateTopicData(Topic) :-
     topicRead(Topic),
     sensitiveTopic(Topic)),
  rule_desc('Attacker exfiltrates topic data',1)).

% ----------------------------------------------------
% D) Runtime sensor-channel abuse
% ----------------------------------------------------

interaction_rule(
  (maliciousTopicContent(Topic) :-
     topicWrite(Topic),
     sensorTopic(Topic),
     attackerCanJoinRosGraph(_Host)),
  rule_desc('Rogue publisher tampers sensor topic content',1)).

interaction_rule(
  (topicDrop(Topic) :-
     targetNodeSelected(Node),
     nodePublishesToTopic(Node,Topic),
     nodeHostedOn(Node,Host),
     attackerCanNetAdmin(Host),
     sensorTopic(Topic)),
  rule_desc('Attacker drops sensor topic via network impairment',1)).

interaction_rule(
  (topicDelay(Topic) :-
     targetNodeSelected(Node),
     nodePublishesToTopic(Node,Topic),
     nodeHostedOn(Node,Host),
     attackerCanNetAdmin(Host),
     sensorTopic(Topic)),
  rule_desc('Attacker delays sensor topic via network impairment',1)).

interaction_rule(
  (qosDegradation(Topic) :-
     targetNodeSelected(Node),
     nodePublishesToTopic(Node,Topic),
     attackerCanJoinRosGraph(_Host),
     sensorTopic(Topic)),
  rule_desc('Authorized rogue participant degrades sensor QoS',1)).

% ----------------------------------------------------
% E) Derived attacker capabilities
% ----------------------------------------------------

interaction_rule(
  (mitmPossible(Topic) :-
     topicRead(Topic),
     topicWrite(Topic)),
  rule_desc('Attacker can read and write topic',1)).

interaction_rule(
  (infoLeak(Topic) :-
     topicRead(Topic)),
  rule_desc('Topic data leaked',1)).

interaction_rule(
  (topicInfluence(Topic) :-
     topicWrite(Topic)),
  rule_desc('Attacker influences topic through external write',1)).

interaction_rule(
  (topicInfluence(Topic) :-
     maliciousTopicContent(Topic)),
  rule_desc('Compromised trusted publisher influences topic',1)).

interaction_rule(
  (parameterTamper(Node) :-
     serviceCall(Srv,Node),
     parameterService(Srv)),
  rule_desc('Attacker tampers parameters',1)).

interaction_rule(
  (lifecycleAbuse(Node) :-
     serviceCall(Srv,Node),
     lifecycleService(Srv)),
  rule_desc('Attacker abuses lifecycle service',1)).

interaction_rule(
  (cryptoInfoLeak(Topic) :-
     mitmPossible(Topic),
     nodePublishesToTopic(Node,Topic),
     programImplementsNode(Program,Node),
     handlesTLS(Program),
     vulExists('crypto_infoleak_family',Program),
     vulProperty('crypto_infoleak_family',remoteExploit,infoLeak)),
  rule_desc('Crypto family leaks data',1)).

interaction_rule(
  (arrayDosExploit(Node,Topic) :-
     topicWrite(Topic),
     nodeSubscribesToTopic(Node,Topic),
     programImplementsNode(Program,Node),
     processesArray(Program,Topic),
     vulExists('GHSA-5545-2q6w-2gh6',Program),
     vulProperty('GHSA-5545-2q6w-2gh6',remoteExploit,dos)),
  rule_desc('Array input triggers DoS exploit',1)).

% ----------------------------------------------------
% F) Direct consequences
% ----------------------------------------------------

interaction_rule(
  (commandIntegrityLoss(Topic) :-
     topicInfluence(Topic),
     controlTopic(Topic)),
  rule_desc('Control topic integrity lost',1)).

interaction_rule(
  (sensorIntegrityLoss(Topic) :-
     topicInfluence(Topic),
     sensorTopic(Topic)),
  rule_desc('Sensor topic integrity lost',1)).

interaction_rule(
  (sensorAvailabilityLoss(Topic) :-
     topicDrop(Topic),
     sensorTopic(Topic)),
  rule_desc('Sensor topic unavailable due to dropped messages',1)).

interaction_rule(
  (sensorAvailabilityLoss(Topic) :-
     topicDelay(Topic),
     sensorTopic(Topic)),
  rule_desc('Sensor topic unavailable due to delayed messages',1)).

interaction_rule(
  (sensorAvailabilityLoss(Topic) :-
     qosDegradation(Topic),
     sensorTopic(Topic)),
  rule_desc('Sensor topic degraded by QoS manipulation',1)).

interaction_rule(
  (configurationIntegrityLoss(Node) :-
     parameterTamper(Node)),
  rule_desc('Configuration integrity lost',1)).

interaction_rule(
  (lifecycleDisruption(Node) :-
     lifecycleAbuse(Node)),
  rule_desc('Lifecycle disrupted',1)).

interaction_rule(
  (dos(Node) :-
     arrayDosExploit(Node,_Topic)),
  rule_desc('Node denied service by exploit',1)).

interaction_rule(
  (dos(Node) :-
     nodeSubscribesToTopic(Node,Topic),
     topicFlood(Topic)),
  rule_desc('Node denied service by topic flood',1)).

% ----------------------------------------------------
% G) System-level consequences
% ----------------------------------------------------

interaction_rule(
  (confidentialityCompromise(Sys) :-
     exfiltrateTopicData(Topic),
     topicBelongsToSystem(Topic,Sys)),
  rule_desc('System confidentiality compromised by topic exfiltration',1)).

interaction_rule(
  (confidentialityCompromise(Sys) :-
     cryptoInfoLeak(Topic),
     topicBelongsToSystem(Topic,Sys)),
  rule_desc('System confidentiality compromised by crypto leak',1)).

interaction_rule(
  (operationalCompromise(Sys) :-
     commandIntegrityLoss(Topic),
     topicBelongsToSystem(Topic,Sys)),
  rule_desc('System operation compromised by control topic loss',1)).

interaction_rule(
  (operationalCompromise(Sys) :-
     sensorIntegrityLoss(Topic),
     topicBelongsToSystem(Topic,Sys)),
  rule_desc('System operation compromised by sensor topic integrity loss',1)).

interaction_rule(
  (operationalCompromise(Sys) :-
     sensorAvailabilityLoss(Topic),
     topicBelongsToSystem(Topic,Sys)),
  rule_desc('System operation compromised by sensor topic delivery loss',1)).

interaction_rule(
  (operationalCompromise(Sys) :-
     configurationIntegrityLoss(Node),
     nodeAffectsSystem(Node,Sys)),
  rule_desc('System operation compromised by parameter tamper',1)).

interaction_rule(
  (operationalCompromise(Sys) :-
     lifecycleDisruption(Node),
     nodeAffectsSystem(Node,Sys)),
  rule_desc('System operation compromised by lifecycle abuse',1)).

interaction_rule(
  (availabilityCompromise(Sys) :-
     dos(Node),
     nodeAffectsSystem(Node,Sys)),
  rule_desc('System availability compromised by node DoS',1)).

% ====================================================
% Leaf -> EFFECT -> systemCompromised
% ====================================================

% Drive denial-of-service.
interaction_rule(
  (drive_DoS(Sys) :-
     topicFlood(Topic),
     controlTopic(Topic),
     topicBelongsToSystem(Topic,Sys)),
  rule_desc('Drive denial of service via topic flood',1)).

% Unsafe command via sustained drift.
interaction_rule(
  (command_unsafe(Sys) :-
     gradualDrift(Topic),
     topicBelongsToSystem(Topic,Sys)),
  rule_desc('Unsafe command via gradual drift',1)).

% Scan corrupted via malicious content / MITM / stale publish.
interaction_rule(
  (scan_corrupted(Sys) :-
     maliciousTopicContent(Topic),
     sensorTopic(Topic),
     topicBelongsToSystem(Topic,Sys)),
  rule_desc('Scan corrupted via malicious content',1)).

interaction_rule(
  (scan_corrupted(Sys) :-
     mitmInjection(Topic),
     topicBelongsToSystem(Topic,Sys)),
  rule_desc('Scan corrupted via MITM injection',1)).

interaction_rule(
  (scan_corrupted(Sys) :-
     stalePublish(Topic),
     sensorTopic(Topic),
     topicBelongsToSystem(Topic,Sys)),
  rule_desc('Scan corrupted via stale publish',1)).

% Scan unreliable via QoS attacks.
interaction_rule(
  (scan_unreliable(Sys) :-
     qosDegradation(Topic),
     sensorTopic(Topic),
     topicBelongsToSystem(Topic,Sys)),
  rule_desc('Scan unreliable via QoS degradation',1)).

interaction_rule(
  (scan_unreliable(Sys) :-
     reliabilityFlip(Topic),
     sensorTopic(Topic),
     topicBelongsToSystem(Topic,Sys)),
  rule_desc('Scan unreliable via reliability flip',1)).

% Scan unreliable via host-level net-admin (tc/iptables).
interaction_rule(
  (scan_unreliable(Sys) :-
     topicDrop(Topic),
     sensorTopic(Topic),
     topicBelongsToSystem(Topic,Sys)),
  rule_desc('Scan unreliable via topic drop',1)).

interaction_rule(
  (scan_unreliable(Sys) :-
     topicDelay(Topic),
     sensorTopic(Topic),
     topicBelongsToSystem(Topic,Sys)),
  rule_desc('Scan unreliable via topic delay',1)).

% Map server down via lifecycle / parameter tamper.
interaction_rule(
  (map_server_down(Sys) :-
     lifecycleHijack(Node),
     nodeAffectsSystem(Node,Sys)),
  rule_desc('Map server down via lifecycle hijack',1)).

interaction_rule(
  (map_server_down(Sys) :-
     lifecycleAbuse(Node),
     nodeAffectsSystem(Node,Sys)),
  rule_desc('Map server down via direct lifecycle abuse',1)).

interaction_rule(
  (map_server_down(Sys) :-
     parameterTamper(map_server),
     nodeAffectsSystem(map_server,Sys)),
  rule_desc('Map server down via direct parameter tamper',1)).

% Bridge misconfigured via parameter tamper.
interaction_rule(
  (bridge_misconfigured(Sys) :-
     serviceCall('/bridge/set_parameters',bridge),
     nodeAffectsSystem(bridge,Sys)),
  rule_desc('Bridge misconfigured via parameter tamper',1)).

% Data leaked via cross-topic correlation or exfil channel.
interaction_rule(
  (data_leaked(Sys) :-
     crossTopicCorrelation(Sys)),
  rule_desc('Data leaked via cross-topic correlation',1)).

interaction_rule(
  (data_leaked(Sys) :-
     exfiltrateChannel(Topic),
     rosTopic(Topic)),
  rule_desc('Data leaked via attacker-created exfil topic',1)).

% Effect -> systemCompromised.
interaction_rule(
  (systemCompromised(Sys) :- drive_DoS(Sys)),
  rule_desc('System compromised via drive DoS',1)).

interaction_rule(
  (systemCompromised(Sys) :- command_unsafe(Sys)),
  rule_desc('System compromised via unsafe command',1)).

interaction_rule(
  (systemCompromised(Sys) :- scan_corrupted(Sys)),
  rule_desc('System compromised via scan corruption',1)).

interaction_rule(
  (systemCompromised(Sys) :- scan_unreliable(Sys)),
  rule_desc('System compromised via scan unreliability',1)).

interaction_rule(
  (systemCompromised(Sys) :- map_server_down(Sys)),
  rule_desc('System compromised via map server down',1)).

interaction_rule(
  (systemCompromised(Sys) :- bridge_misconfigured(Sys)),
  rule_desc('System compromised via bridge misconfiguration',1)).

interaction_rule(
  (systemCompromised(Sys) :- data_leaked(Sys)),
  rule_desc('System compromised via data leak',1)).

% ----------------------------------------------------
% H) Second-stage escalation attacks
% ----------------------------------------------------

% MITM injection on a topic.
interaction_rule(
  (mitmInjection(Topic) :-
     mitmPossible(Topic),
     attackerCanJoinRosGraph(_Host)),
  rule_desc('Attacker runs MITM injection on topic',1)).

% Gradual drift on a control topic.
interaction_rule(
  (gradualDrift(Topic) :-
     topicWrite(Topic),
     controlTopic(Topic)),
  rule_desc('Attacker gradually drifts control values toward unsafe envelope',1)).

% Stale-timestamped publication.
interaction_rule(
  (stalePublish(Topic) :-
     topicWrite(Topic)),
  rule_desc('Attacker publishes stale-timestamped messages',1)).

% Cross-topic correlation on /scan + /odom.
interaction_rule(
  (crossTopicCorrelation(Sys) :-
     topicRead('/scan'),
     topicRead('/odom'),
     sensitiveTopic('/scan'),
     sensitiveTopic('/odom'),
     topicBelongsToSystem('/scan',Sys),
     topicBelongsToSystem('/odom',Sys)),
  rule_desc('Attacker correlates multiple sensitive topics',1)).

% Attacker-created exfil channel.
interaction_rule(
  (exfiltrateChannel(Topic) :-
     topicRead(SrcTopic),
     sensitiveTopic(SrcTopic),
     attackerCanJoinRosGraph(_Host),
     attackerCreatedTopic(Topic)),
  rule_desc('Attacker creates new topic and dumps stolen data',1)).

% QoS reliability flip on a sensor topic.
interaction_rule(
  (reliabilityFlip(Topic) :-
     qosDegradation(Topic),
     sensorTopic(Topic)),
  rule_desc('Attacker oscillates QoS reliability to disrupt subscribers',1)).

% Lifecycle hijack: disrupt + tamper + re-activate.
interaction_rule(
  (lifecycleHijack(Node) :-
     lifecycleDisruption(Node),
     parameterTamper(Node),
     lifecycleService(Srv),
     serviceServer(Srv,Node)),
  rule_desc('Attacker hijacks lifecycle node with malicious config',1)).

% ----------------------------------------------------
% I) Escalation -> direct consequence
% ----------------------------------------------------

interaction_rule(
  (commandIntegrityLoss(Topic) :-
     mitmInjection(Topic),
     controlTopic(Topic)),
  rule_desc('Control integrity lost via MITM injection',1)).

interaction_rule(
  (sensorIntegrityLoss(Topic) :-
     mitmInjection(Topic),
     sensorTopic(Topic)),
  rule_desc('Sensor integrity lost via MITM injection',1)).

interaction_rule(
  (commandIntegrityLoss(Topic) :-
     gradualDrift(Topic),
     controlTopic(Topic)),
  rule_desc('Control integrity lost via gradual drift',1)).

interaction_rule(
  (sensorIntegrityLoss(Topic) :-
     stalePublish(Topic),
     sensorTopic(Topic)),
  rule_desc('Sensor integrity lost via stale publish',1)).

interaction_rule(
  (confidentialityCompromise(Sys) :-
     crossTopicCorrelation(Sys)),
  rule_desc('Confidentiality compromised by cross-topic correlation',1)).

interaction_rule(
  (sensorAvailabilityLoss(Topic) :-
     reliabilityFlip(Topic),
     sensorTopic(Topic)),
  rule_desc('Sensor availability lost via QoS reliability flip',1)).

interaction_rule(
  (operationalCompromise(Sys) :-
     lifecycleHijack(Node),
     nodeAffectsSystem(Node,Sys)),
  rule_desc('System operation compromised by lifecycle hijack',1)).
